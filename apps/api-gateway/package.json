{
  "name": "@library/api-gateway",
  "version": "1.0.0",
  "description": "GraphQL API Gateway - unified entry point for all library services",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@library/shared-kernel": "workspace:*",
    "@library/book-service": "workspace:*",
    "@library/author-service": "workspace:*",
    "@apollo/server": "^4.10.0",
    "graphql": "^16.8.0",
    "graphql-tag": "^2.12.0",
    "@graphql-tools/schema": "^10.0.0",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
